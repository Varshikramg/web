## 7. View Codes

### `app/views/posts/index.html.erb`

```erb
<h1>Posts</h1>

<% if @posts.any? %>
  <ul>
    <% @posts.each do |post| %>
      <li>
        <strong><%= post.title.presence || "Untitled Post" %></strong>
        - <%= post.published? ? "Published" : "Draft" %>
        - Author: <%= post.user&.name.presence || "Unknown User" %>
        - Category: <%= post.category&.name.presence || "Uncategorized" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No posts found yet.</p>
<% end %>
```

### `app/views/users/index.html.erb`

```erb
<h1>Users</h1>

<% if @users.any? %>
  <ul>
    <% @users.each do |user| %>
      <li>
        <strong><%= user.name.presence || "Unnamed User" %></strong>
        <% if user.email.present? %>
          (<%= user.email %>)
        <% end %>
        - Posts: <%= user.posts.size %>, Comments: <%= user.comments.size %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No users found yet.</p>
<% end %>
```

### `app/views/categories/index.html.erb`

```erb
<h1>Categories</h1>

<% if @categories.any? %>
  <ul>
    <% @categories.each do |category| %>
      <li>
        <strong><%= category.name.presence || "Unnamed Category" %></strong>
        - Posts: <%= category.posts.size %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No categories found yet.</p>
<% end %>
```

### `app/views/comments/index.html.erb`

```erb
<h1>Comments</h1>

<% if @comments.any? %>
  <ul>
    <% @comments.each do |comment| %>
      <li>
        <strong><%= comment.user&.name.presence || "Unknown User" %></strong>
        on
        <em><%= comment.post&.title.presence || "Untitled Post" %></em>:
        <%= comment.body %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No comments found yet.</p>
<% end %>
```

